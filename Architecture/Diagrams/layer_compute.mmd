    classDef hostprep   fill:#162B00,stroke:#4A8500,stroke-width:1px,color:#C8E6C9
    classDef transfer   fill:#0D1F00,stroke:#76B900,stroke-width:2px,color:#DCEDC8
    classDef nvidia     fill:#1E3300,stroke:#76B900,stroke-width:2px,color:#fff
    classDef kernel     fill:#2A4500,stroke:#9ACD00,stroke-width:1px,color:#E8F5E9
    classDef constraint fill:#2A1515,stroke:#922B21,stroke-width:1px,color:#F1948A
    classDef note       fill:#182800,stroke:#4A8500,stroke-width:1px,color:#AED581
    classDef output     fill:#7A3D00,stroke:#E67E22,stroke-width:3px,color:#FDEBD0

