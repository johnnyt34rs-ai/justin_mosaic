%%{init: {'theme': 'dark', 'flowchart': {'curve': 'basis', 'nodeSpacing': 45, 'rankSpacing': 55}}}%%
flowchart TD

    CHUNK([Chunk Work Item\ncell_lab array · chunk_local_idx]):::input
    TILEDB([Tile Dataset\nPre-computed LAB representative colors]):::input

    CELLBUF[Pack Cell LAB to Contiguous Host Buffer\nSoA layout: cell_L, cell_a, cell_b]:::hostprep
    TILEBUF[Pack Tile LAB to Contiguous Host Buffer\nSoA layout: tile_L, tile_a, tile_b]:::hostprep
    HtoD[cudaMemcpy Host to Device\nCell buffer + Tile buffer\nOne transfer per chunk]:::transfer

    subgraph KERNEL [" CUDA Kernel · match_tiles · blockDim = 256 "]
        DISP[GPU Dispatch\nOne thread per mosaic cell]:::nvidia
        READ[Thread: Read cell_lab at idx\nfloat3 from device buffer]:::kernel
        LOOP[Iterate all tiles\nCompute dE^2 = dL^2 + da^2 + db^2\nsqrt deferred - monotone under min]:::kernel
        MIN[Track min dE^2 and tile index\nFLT_MAX init · in-register]:::kernel
        WRITE[Write tile_id at idx\nto output device buffer]:::kernel
    end

    DtoH[cudaMemcpy Device to Host\ntile_id array\nOne transfer per chunk]:::transfer
    OUT([tile_id Array\n.npy sidecar per chunk\nConsumed by USD export stage]):::output

    subgraph MEM [" Memory Constraints "]
        M1[Tile LAB must fit VRAM\n12B x num_tiles · batch if exceeds]:::constraint
        M2[SoA layout required\nCoalesced global memory access]:::constraint
        M3[Single Host-to-Device transfer\nAll inputs before kernel launch]:::constraint
        M4[Single Device-to-Host transfer\ntile_id only after kernel completes]:::constraint
    end

    BATCH[Batching for Large Tile Sets\nPartial tile buffers · multiple launches\nPersistent per-cell minimum across batches]:::note

    CHUNK  --> CELLBUF
    TILEDB --> TILEBUF
    CELLBUF & TILEBUF --> HtoD
    HtoD --> DISP
    DISP --> READ
    READ --> LOOP
    LOOP --> MIN
    MIN --> WRITE
    WRITE --> DtoH
    DtoH --> OUT
    TILEBUF -.->|if exceeds VRAM| BATCH
    BATCH   -.-> DISP

