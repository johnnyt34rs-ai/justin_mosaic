%%{init: {'theme': 'dark', 'flowchart': {'curve': 'basis', 'nodeSpacing': 45, 'rankSpacing': 55}}}%%
flowchart TD

    ASSIGN([tile_id Array + Chunk Geometry\n.npy sidecar · .bgeo.sc chunk]):::input
    MESHLIB([Tile Mesh Library\nUnit-scale quad meshes · UV primvars]):::input

    PROTOS[Build Prototype Set\nOne UsdGeomMesh per tile type\nShared across all chunks · authored once]:::usd

    subgraph PROTOSET [" /Mosaic/Prototypes  (prototype_set.usda) "]
        P0[Tile_0000\nUsdGeomMesh · unit quad · primvars:st]:::protomesh
        P1[Tile_0001\nUsdGeomMesh · unit quad · primvars:st]:::protomesh
        PN[Tile_N\nUsdGeomMesh · unit quad · primvars:st]:::protomesh
    end

    INST[Build UsdGeomPointInstancer\n/Mosaic/Chunk_XXXX/Instances]:::usd

    subgraph PIATTRS [" PointInstancer Attributes "]
        PA[positions · VtArray GfVec3f\nWorld-space · no chunk-local offsets]:::piattr
        PB[protoIndices · VtArray int\nIndex into /Mosaic/Prototypes]:::piattr
        PC[orientations · VtArray GfQuatf\nPer-instance rotation]:::piattr
        PD[scales · VtArray GfVec3f\nPer-instance scale]:::piattr
        PE[prototypes rel\nTargets /Mosaic/Prototypes/*]:::piattr
    end

    CHUNKFILE[USD Chunk File\nchunk_XXXX.usd\nReferences prototype_set.usda\nValid standalone stage]:::usd

    ROOT[mosaic_root.usda\nsubLayers all chunk USDs\nUnique prim path per chunk\nNo array composition conflicts]:::usdroot

    OUT([Aggregated USD Scene\nmosaic_root.usda\nReady for Hydra · Unreal · Karma · Arnold]):::output

    subgraph CONS [" USD Constraints "]
        C1[No per-instance UsdGeomMesh prims\nAll geometry in /Mosaic/Prototypes only]:::constraint
        C2[Chunk USDs valid as standalone stages\nOpenable independently for debug]:::constraint
        C3[Stable prim paths across re-cooks\nNo hash-based or timestamp naming]:::constraint
        C4[Use payload arcs above 1000 chunks\nEnables deferred per-chunk loading]:::constraint
    end

    MESHLIB --> PROTOS
    PROTOS --> P0 & P1 & PN

    ASSIGN --> INST
    INST --> PA & PB & PC & PD & PE

    PA & PB & PC & PD & PE --> CHUNKFILE
    P0 & P1 & PN --> CHUNKFILE

    CHUNKFILE --> ROOT
    ROOT --> OUT

