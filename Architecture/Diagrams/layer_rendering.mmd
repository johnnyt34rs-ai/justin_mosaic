%%{init: {'theme': 'dark', 'flowchart': {'curve': 'basis', 'nodeSpacing': 45, 'rankSpacing': 55}}}%%
flowchart TD

    USD([mosaic_root.usda\nAggregated USD Scene\nPointInstancer per chunk]):::input

    STAGE[USD Stage Actor\nLive USD streaming\nRespects layer composition]:::unreal
    PARSE[Parse UsdGeomPointInstancer\nPositions · protoIndices · orientations · scales]:::unreal

    HISM[Convert to HISM\nUHierarchicalInstancedStaticMeshComponent\nOne component per unique prototype]:::hism

    subgraph HISMINFO [" HISM Properties "]
        H1[Draw calls = num unique tile types\nNot total instance count]:::hismprop
        H2[GPU occlusion culling\nAutomatic per HISM component]:::hismprop
        H3[LOD management\nPer-prototype · not per-instance]:::hismprop
        H4[Nanite DISABLED\n2-tri quad meshes · HISM is faster]:::warn
    end

    MAT[Assign Material Instances\nOne per prototype · shared Master Material]:::mat

    subgraph MATPARAMS [" Master Material Parameters "]
        MP1[TileTexture · Texture2D\nPer-prototype tile image]:::matparam
        MP2[TileID · int\nProcedural variation]:::matparam
        MP3[TileColorTint · LinearColor\nLAB-driven correction]:::matparam
    end

    LIGHT[Lighting Pass\nLumen GI · Surface Cache]:::render
    RENDER[GPU-Driven Render\nHISM draw call batches]:::render

    MODE{Output Mode}:::decision

    RT[Real-Time Viewport\nDefault HISM · Lumen enabled\nTarget below 500 draw calls]:::rtout
    OFFLINE[Movie Render Queue\nPath Tracer · Lumen High Quality]:::offout
    INSTALL[Packaged Build\nFixed camera · frustum culling\nGPU instancing forced]:::offout

    LUMEN[Lumen Notes\nDisable on emissive tiles\nSurface Cache conservative at scale]:::note

    USD --> STAGE
    STAGE --> PARSE
    PARSE --> HISM
    HISM --> MAT
    MAT --> MP1 & MP2 & MP3
    MP1 & MP2 & MP3 --> LIGHT
    LIGHT --> RENDER
    RENDER --> MODE
    MODE --> RT
    MODE --> OFFLINE
    MODE --> INSTALL
    LIGHT -.-> LUMEN

