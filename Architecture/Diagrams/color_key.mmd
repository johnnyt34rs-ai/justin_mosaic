flowchart LR

    subgraph PIPELINE [" Pipeline Layers "]
        L1[Houdini Authoring\nSideFX brand orange]:::houdini
        L2[PDG Distribution\nSideFX dark orange\nSame family · subdued]:::pdg
        L3[GPU Compute\nNVIDIA brand green\nhex 76B900 exact]:::nvidia
        L4[USD Representation\nOpenUSD steel blue\nPixar documentation color]:::usd
        L5[Unreal Rendering\nEpic Games dark blue\nUE5 brand color]:::unreal
    end

    subgraph IO [" Data Boundaries "]
        D1[Input Node\nNeutral dark slate\nAll pipeline entry points]:::input
        D2[Output Node\nWarm amber\nAll pipeline deliverables]:::output
    end

    subgraph META [" Diagram Metadata "]
        M1[Constraint\nDark red\nAll hard limits and rules]:::constraint
        M2[Note / Advisory\nMuted green\nNon-blocking guidance]:::note
        M3[Decision Point\nNeutral slate\nBranching output modes]:::decision
    end

    subgraph SUBLAYERS [" Sublayer Tints  within GPU layer "]
        S1[Host Prep\nDark olive\nCPU-side buffer packing]:::hostprep
        S2[Memory Transfer\nNVIDIA green dim\ncudaMemcpy operations]:::transfer
        S3[Kernel Op\nNVIDIA green bright\nOn-device thread work]:::kernel
    end

    subgraph USDLAYERS [" Sublayer Tints  within USD layer "]
        U1[Prototype Mesh\nUSB blue dark\nUsdGeomMesh prims]:::protomesh
        U2[PointInstancer Attr\nUSD blue deep\nVtArray attributes]:::piattr
        U3[Root Composition\nUSD blue accent\nmosaic_root.usda]:::usdroot
    end

    subgraph UNREALLAYERS [" Sublayer Tints  within Unreal layer "]
        R1[HISM Component\nEpic blue mid\nUHISMComponent]:::hism
        R2[Material\nEpic blue light\nMaster Material params]:::mat
        R3[Warning\nDark amber-red\nNanite disabled etc]:::warn
    end

